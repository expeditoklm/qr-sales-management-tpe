# JWT
JWT_SECRET=changez-moi-min-32-caracteres-aleatoires
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
INVITE_TOKEN_EXPIRE_HOURS=48

# Super-Admin (premier compte créé au démarrage)
SUPERADMIN_EMAIL=admin@tpe-qr.com
SUPERADMIN_PASSWORD=changez-moi-fort

# CORS (liste séparée par virgules, sans espaces)
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Rate limiting (requêtes / fenêtre en secondes)
RATE_LIMIT_VERIFY_REQUESTS=10
RATE_LIMIT_VERIFY_WINDOW=60
RATE_LIMIT_LOGIN_REQUESTS=5
RATE_LIMIT_LOGIN_WINDOW=60

# Stripe (optionnel — commenter si non utilisé)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BASIC=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

